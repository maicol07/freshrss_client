<Page
    x:Class="FreshRssClient.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <NavigationView x:Name="MainNavigationView"
                        PaneDisplayMode="Left"
                        IsSettingsVisible="true"
                        IsBackButtonVisible="Collapsed"
                        AlwaysShowHeader="false"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        SelectionChanged="OnNavigationSelectionChanged">
            <NavigationView.Content>
                <Grid x:Name="ContentGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Page>
