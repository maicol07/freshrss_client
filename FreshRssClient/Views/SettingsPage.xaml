<Page
    x:Class="FreshRssClient.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:labs="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <ScrollViewer x:Name="RootScrollViewer" Padding="24" HorizontalAlignment="Stretch" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" MaxWidth="1000" HorizontalAlignment="Left" Width="600">
            <!-- Header -->
            <TextBlock x:Name="SettingsTitle" 
                       FontSize="28" 
                       FontWeight="SemiBold"
                       Margin="0,0,0,16"/>

            <!-- 1. Account / Connection Expander -->
            <labs:SettingsExpander x:Name="AccountExpander" IsExpanded="true">
                <labs:SettingsExpander.HeaderIcon>
                    <SymbolIcon Symbol="Contact"/>
                </labs:SettingsExpander.HeaderIcon>
                
                <labs:SettingsExpander.Items>
                    <!-- Server URL Card -->
                    <labs:SettingsCard x:Name="ServerUrlCard">
                        <TextBox x:Name="ServerUrlInput" Width="300" PlaceholderText="https://example.com/api/greader.php" LostFocus="OnServerUrlLostFocus"/>
                    </labs:SettingsCard>

                    <!-- Username Card -->
                    <labs:SettingsCard x:Name="UsernameCard">
                        <TextBox x:Name="UsernameInput" Width="300" LostFocus="OnUsernameLostFocus"/>
                    </labs:SettingsCard>

                    <!-- Password Card -->
                    <labs:SettingsCard x:Name="PasswordCard">
                        <PasswordBox x:Name="PasswordInput" Width="300" LostFocus="OnPasswordLostFocus"/>
                    </labs:SettingsCard>
                </labs:SettingsExpander.Items>
            </labs:SettingsExpander>

            <!-- 2. Sync & Limits Expander -->
            <labs:SettingsExpander x:Name="SyncExpander" IsExpanded="true">
                <labs:SettingsExpander.HeaderIcon>
                    <SymbolIcon Symbol="Sync"/>
                </labs:SettingsExpander.HeaderIcon>

                <labs:SettingsExpander.Items>
                    <!-- Sync Interval NumberBox -->
                    <labs:SettingsCard x:Name="IntervalCard">
                        <NumberBox x:Name="IntervalNumberBox" 
                                   Width="150" 
                                   Minimum="1" 
                                   SpinButtonPlacementMode="Compact" 
                                   SmallChange="1" 
                                   LargeChange="5"
                                   LostFocus="OnIntervalLostFocus"/>
                    </labs:SettingsCard>

                    <!-- Max Read Articles NumberBox -->
                    <labs:SettingsCard x:Name="MaxReadCard">
                        <NumberBox x:Name="MaxReadNumberBox" 
                                   Width="150" 
                                   Minimum="1" 
                                   SpinButtonPlacementMode="Compact" 
                                   SmallChange="5" 
                                   LargeChange="25"
                                   LostFocus="OnMaxReadLostFocus"/>
                    </labs:SettingsCard>
                </labs:SettingsExpander.Items>
            </labs:SettingsExpander>

            <!-- 3. Reading Options Expander -->
            <labs:SettingsExpander x:Name="ReadingExpander" IsExpanded="true">
                <labs:SettingsExpander.HeaderIcon>
                    <SymbolIcon Symbol="Document"/>
                </labs:SettingsExpander.HeaderIcon>

                <labs:SettingsExpander.Items>
                    <!-- OpenGraph Toggle -->
                    <labs:SettingsCard x:Name="OpenGraphCard">
                        <ToggleSwitch x:Name="OpenGraphToggle" Toggled="OnOpenGraphToggled"/>
                    </labs:SettingsCard>

                    <!-- Default Filter ComboBox -->
                    <labs:SettingsCard x:Name="DefaultFilterCard">
                        <ComboBox x:Name="DefaultFilterComboBox" Width="150" SelectionChanged="OnDefaultFilterSelectionChanged"/>
                    </labs:SettingsCard>

                    <!-- Open in Browser Toggle -->
                    <labs:SettingsCard x:Name="OpenInBrowserCard">
                        <ToggleSwitch x:Name="OpenInBrowserToggle" Toggled="OnOpenInBrowserToggled"/>
                    </labs:SettingsCard>
                </labs:SettingsExpander.Items>
            </labs:SettingsExpander>

            <!-- 4. System Integration Expander -->
            <labs:SettingsExpander x:Name="SystemExpander" IsExpanded="true">
                <labs:SettingsExpander.HeaderIcon>
                    <SymbolIcon Symbol="Setting"/>
                </labs:SettingsExpander.HeaderIcon>

                <labs:SettingsExpander.Items>
                    <!-- AutoStart Toggle -->
                    <labs:SettingsCard x:Name="AutoStartCard">
                        <ToggleSwitch x:Name="AutoStartToggle" Toggled="OnAutoStartToggled"/>
                    </labs:SettingsCard>

                    <!-- Start Minimized Toggle -->
                    <labs:SettingsCard x:Name="StartMinimizedCard">
                        <ToggleSwitch x:Name="StartMinimizedToggle" Toggled="OnStartMinimizedToggled"/>
                    </labs:SettingsCard>
                </labs:SettingsExpander.Items>
            </labs:SettingsExpander>

            <!-- 5. Language Card -->
            <labs:SettingsCard x:Name="LanguageCard">
                <labs:SettingsCard.HeaderIcon>
                    <SymbolIcon Symbol="Character"/>
                </labs:SettingsCard.HeaderIcon>
                <ComboBox x:Name="LanguageComboBox" Width="150" SelectionChanged="OnLanguageSelectionChanged"/>
            </labs:SettingsCard>

            <!-- Network / Connection Status -->
            <TextBlock x:Name="StatusText" FontSize="13" FontWeight="Medium" Margin="0,16,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>
